# @name users_create
# @covers POST /api/users
POST {{baseUrl}}/api/users
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "userName": "apitest{{runSuffix}}",
  "email": "apitest{{runSuffix}}@booksportal.local",
  "password": "{{tempUserPassword}}",
  "fullName": "API Test {{runSuffix}}",
  "nationalId": "UN{{runSuffix}}",
  "designation": "Automation",
  "roles": ["User"]
}

?? status >= 200 && status < 300
@userId={{response.parsedBody.data.id}}
?? response.parsedBody.data.id != null

