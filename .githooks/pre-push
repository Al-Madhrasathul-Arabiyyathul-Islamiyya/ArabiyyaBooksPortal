#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

upstream_ref="$(git rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null || true)"

if [[ -n "$upstream_ref" ]]; then
  diff_range="${upstream_ref}...HEAD"
elif git rev-parse --verify HEAD~1 >/dev/null 2>&1; then
  diff_range="HEAD~1...HEAD"
else
  diff_range=""
fi

if [[ -n "$diff_range" ]]; then
  mapfile -t changed_files < <(git diff --name-only --diff-filter=ACMR "$diff_range" 2>/dev/null || true)
else
  mapfile -t changed_files < <(git ls-files)
fi
if [[ ${#changed_files[@]} -eq 0 ]]; then
  exit 0
fi

backend_changed=false
frontend_changed=false

for file in "${changed_files[@]}"; do
  [[ "$file" == BooksPortal/* ]] && backend_changed=true
  [[ "$file" == BooksPortalFrontEnd/* ]] && frontend_changed=true
done

if [[ "$backend_changed" == true ]]; then
  echo "[pre-push] Running backend build and test gates..."
  dotnet build "$repo_root/BooksPortal/BooksPortal.slnx"
  dotnet test "$repo_root/BooksPortal/tests/BooksPortal.UnitTests/BooksPortal.UnitTests.csproj"
  dotnet test "$repo_root/BooksPortal/tests/BooksPortal.IntegrationTests/BooksPortal.IntegrationTests.csproj"
fi

if [[ "$frontend_changed" == true ]]; then
  echo "[pre-push] Running frontend build and test gates..."
  (
    cd "$repo_root/BooksPortalFrontEnd"
    bun run lint
    bunx nuxi typecheck
    bun run test:unit
    bun run test:nuxt
  )
fi
