{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=BooksPortalDev;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "Secret": "YourSuperSecretKeyThatIsAtLeast32CharactersLong!",
    "Issuer": "BooksPortal",
    "Audience": "BooksPortalClient",
    "ExpiryInMinutes": 240,
    "RefreshTokenExpiryInDays": 7,
    "ClockSkewSeconds": 30,
    "SigningMode": "Symmetric",
    "CertificatePath": "",
    "CertificatePassword": "",
    "CertificateBase64": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "SlipStorage": {
    "BasePath": "D:\\SlipStorage"
  },
  "ImportTemplateCache": {
    "StoragePath": "App_Data/import-templates"
  },
