# Copy to infra/.env.local or set in your shell
BP_API_PORT=5071
BP_FRONTEND_PORT=3000

# Required API settings
BP_DB_CONNECTION=Server=host.docker.internal,1433;Database=BooksPortal;User Id=booksportal_app;Password=ChangeThis!123;TrustServerCertificate=True;Encrypt=False;MultipleActiveResultSets=True
BP_JWT_SIGNING_MODE=Symmetric
BP_JWT_SECRET=CHANGE_ME_AT_DEPLOYMENT
BP_JWT_ISSUER=BooksPortal
BP_JWT_AUDIENCE=BooksPortalClient
BP_SUPERADMIN_USERNAME=admin
BP_SUPERADMIN_EMAIL=admin@booksportal.local
BP_SUPERADMIN_PASSWORD=CHANGE_ME_AT_DEPLOYMENT
BP_SUPERADMIN_FULLNAME=System Administrator
BP_SUPERADMIN_NID=A0000001
BP_SUPERADMIN_DESIGNATION=System Administrator

# Required frontend settings
BP_PUBLIC_API_BASE=http://localhost:5071/api
BP_PUBLIC_APP_TITLE=Arabiyya Academic Books Portal

# Optional tuning
BP_API_ENVIRONMENT=Production
BP_JWT_EXPIRY_MINUTES=240
BP_JWT_REFRESH_DAYS=7
BP_JWT_CLOCK_SKEW_SECONDS=30
BP_CORS_ORIGIN_0=http://localhost:3000
BP_NODE_EXTRA_CA_CERTS=
