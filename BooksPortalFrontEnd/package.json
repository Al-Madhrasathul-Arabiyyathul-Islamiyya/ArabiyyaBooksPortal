{
  "name": "BooksPortalFrontEnd",
  "version": "0.10.0",
  "dependencies": {
    "@nuxt/eslint": "1.13.0",
    "@nuxt/fonts": "0.13.0",
    "@nuxt/hints": "1.0.0-alpha.6",
    "@nuxt/icon": "2.2.1",
    "@nuxt/image": "2.0.0",
    "@nuxtjs/color-mode": "4.0.0",
    "@pinia/colada": ">=0.21.2",
    "@pinia/colada-nuxt": "0.3.1",
    "@pinia/nuxt": "0.11.3",
    "@primeuix/themes": "^2.0.3",
    "@primevue/nuxt-module": "4.5.4",
    "@regle/core": "^1.18.3",
    "@regle/nuxt": "1.18.3",
    "@regle/rules": "^1.18.3",
    "@regle/schemas": "^1.18.3",
    "@tailwindcss/vite": "^4.1.18",
    "dayjs-nuxt": "2.1.11",
    "eslint": "^9.0.0",
    "nuxt": "^4.3.0",
    "nuxt-csurf": "^1.6.5",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "tailwindcss": "^4.1.18",
    "tailwindcss-primeui": "^0.6.1",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "analyze": "nuxt analyze",
    "test:unit": "vitest run --project unit",
    "test:nuxt": "vitest run --project nuxt",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install",
    "test:e2e:auth": "playwright test tests/e2e/auth-guards.spec.ts",
    "test:unit:lifecycle": "vitest run tests/unit/useSlipLifecycle.spec.ts",
    "test:unit:pagination": "vitest run tests/unit/usePagination.spec.ts",
    "test:smoke": "bun run test:unit && bun run test:e2e:auth",
    "test:all": "bun run test:unit && bun run test:e2e"
  },
  "type": "module",
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@vitest/ui": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.6.1",
    "playwright": "^1.58.2",
    "vitest": "^4.0.18"
  }
}
